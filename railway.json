{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "nixpacksPlan": {
            "providers": [
                "python"
            ]
        },
        "buildCommand": "pip install -r requirements-deploy.txt && chmod +x start.sh"
    },
    "deploy": {
        "startCommand": "bash start.sh",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}